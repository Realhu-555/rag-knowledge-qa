# DeepSeek API配置
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Embedding配置
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# 切片配置
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# 检索配置
RETRIEVAL_TOP_K=10

# LLM配置
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
